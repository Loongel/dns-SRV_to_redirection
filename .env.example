# Worker deploy helper
WORKER_NAME=dns-srv-to-redirection
WRANGLER_CONFIG=wrangler.toml

# Live smoke test
PORTAL_URL=https://s.example.com
PORTAL_PASSWD=change-me

# OpenWrt deploy/smoke helpers
OPENWRT_HOST=wrt
OPENWRT_AGENT_PATH=/etc/natmap/natmap-portal-agent.sh
OPENWRT_DDNS_PATH=/etc/natmap/ddns/Cloudflare
OPENWRT_CONFIGURE_CUSTOM_SCRIPT=0
OPENWRT_CUSTOM_SCRIPT_SECTION=@natmap[0]
