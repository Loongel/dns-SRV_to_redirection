# depends jsonfilter

. /usr/lib/natmap/common.sh
. /usr/share/libubox/jshn.sh

api_base() {
	echo "https://api.cloudflare.com/client/v4/zones/${ZONE_ID}/dns_records"
}

cf_request() {
	local method="$1"
	local path="$2"
	local data="$3"

	if [ -n "$data" ]; then
		$CURL $retry -L -sS -X "$method" \
			--url "$(api_base)${path}" \
			-H "Authorization: Bearer ${TOKEN}" \
			-H 'Content-Type: application/json' \
			-d "$data"
	else
		$CURL $retry -L -sS -X "$method" \
			--url "$(api_base)${path}" \
			-H "Authorization: Bearer ${TOKEN}" \
			-H 'Content-Type: application/json'
	fi
}

record_ids_by_name() {
	local type="$1"
	local name="$2"
	jsonfilter -s "$records" -qe @.result[*] \
		| grep -F "\"type\": \"${type}\"" \
		| grep -F "\"name\": \"${name}\"" \
		| while IFS= read -r the_record; do
			jsonfilter -s "$the_record" -qe @.id
		done
}

delete_records_by_name() {
	local type="$1"
	local name="$2"
	local id

	for id in $(record_ids_by_name "$type" "$name"); do
		[ -n "$id" ] || continue
		cf_request DELETE "/${id}" >/dev/null || return 1
	done
}

replace_record_by_name() {
	local type="$1"
	local name="$2"
	local data="$3"

	delete_records_by_name "$type" "$name" || return 1
	cf_request POST "" "$data" >/dev/null
}

cleanup_records() {
	local rc=0

	if [ -n "${srv}" ] && [ -n "${srv_serv}" ]; then
		delete_records_by_name "SRV" "_${srv_serv}._${srv_proto:-tcp}.${srv}" || rc=1
	fi
	if [ -n "${https}" ]; then
		delete_records_by_name "HTTPS" "${https}" || rc=1
	fi
	if [ "${cleanup_host:-0}" = 1 ] && [ -n "${host}" ] && [ -n "${hostype}" ]; then
		delete_records_by_name "${hostype}" "${host}" || rc=1
	fi
	return "$rc"
}

start() {
	local retry='--connect-timeout 3 --max-time 20 --retry 2 --retry-delay 2'
	local records
	records="$(cf_request GET "?per_page=5000" "")"
	[ -z "$records" -o -n "$(grep -E "\"success\":\s*false" <<< "$records")" ] && return 1

	if [ "${cleanup:-0}" = 1 ]; then
		cleanup_records
		return $?
	fi

	if [ -n "$host" ]; then
		json_init
		json_add_string type "${hostype}"
		json_add_string name "${host}"
		json_add_string content "${ip}"
		json_add_int ttl 1
		json_add_boolean proxied 0
		replace_record_by_name "${hostype}" "${host}" "$(json_dump)" || return 1
	fi

	if [ -n "${srv}" ]; then
		json_init
		json_add_string type "SRV"
		json_add_string name "_${srv_serv}._${srv_proto}.${srv}"
		json_add_object data
			json_add_int priority "${srv_priority}"
			json_add_int weight "${srv_weight}"
			json_add_int port "${port}"
			json_add_string target "${srv_target}"
		json_close_object
		json_add_int ttl 1
		json_add_boolean proxied 0
		replace_record_by_name "SRV" "_${srv_serv}._${srv_proto}.${srv}" "$(json_dump)" || return 1
	fi

	if [ -n "${https}" ]; then
		local _svcparams="${https_svcparams}"
		_svcparams="$(echo "$_svcparams" | sed -E "s,\s*(port=[0-9]*|$), port=${port},")"
		[ "$hostype" = A ]    && _svcparams="$(echo "$_svcparams" | sed -E "s|\b(ipv4hint=)\S*|\1${ip}|")"
		[ "$hostype" = AAAA ] && _svcparams="$(echo "$_svcparams" | sed -E "s|\b(ipv6hint=)\S*|\1${ip}|")"

		json_init
		json_add_string type "HTTPS"
		json_add_string name "${https}"
		json_add_object data
			json_add_int priority "${https_priority}"
			json_add_string target "${https_target}"
			json_add_string value "${_svcparams}"
		json_close_object
		json_add_int ttl 1
		json_add_boolean proxied 0
		replace_record_by_name "HTTPS" "${https}" "$(json_dump)" || return 1
	fi
}

ALL_PARAMS="hostype host srv srv_serv srv_proto srv_target srv_priority srv_weight ip port https https_target https_svcparams https_priority cleanup cleanup_host tokens"
eval "$(JSON_EXPORT "$1")"; shift
INIT_GLOBAL_VAR TOKEN ZONE_ID
case "$tokens" in *"<"*|*">"*) exit 1;; esac
eval "$tokens"
start "$@"
